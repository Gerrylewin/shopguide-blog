# Clerk (https://dashboard.clerk.com → API keys)
# Publishable keys often end with a literal $ — in .env files that character is special. Use single quotes:
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY='pk_test_...your_key...$'
# CLERK_SECRET_KEY='sk_test_...'
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Cloudflare D1 (newsletter + sent-post state). REST API: Account → D1 → Edit for this token.
# https://developers.cloudflare.com/d1/tutorials/import-to-d1-with-rest-api/
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_D1_DATABASE_ID=

# Optional: dedicated API token for blog thumbs up/down only (same account + D1 database UUID).
# When set, vote routes use this token and ignore CLOUDFLARE_API_TOKEN for D1 vote queries.
# Account → D1 → Edit. Leave unset to use CLOUDFLARE_API_TOKEN for votes too.
CLOUDFLARE_API_TOKEN_BLOG_VOTES=

# visit https://giscus.app to get your Giscus ids
NEXT_PUBLIC_GISCUS_REPO=Gerrylewin/shopguide-blog
NEXT_PUBLIC_GISCUS_REPOSITORY_ID=R_kgDOQSURWg
NEXT_PUBLIC_GISCUS_CATEGORY=Announcements
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_kwDOQSURWs4Cxncs
NEXT_PUBLIC_UTTERANCES_REPO=
NEXT_PUBLIC_DISQUS_SHORTNAME=


MAILCHIMP_API_KEY=
MAILCHIMP_API_SERVER=
MAILCHIMP_AUDIENCE_ID=

BUTTONDOWN_API_KEY=

CONVERTKIT_API_KEY=
# curl https://api.convertkit.com/v3/forms?api_key=<your_public_api_key> to get your form ID
CONVERTKIT_FORM_ID=

KLAVIYO_API_KEY=
KLAVIYO_LIST_ID=

REVUE_API_KEY=

# Create EmailOctopus API key at https://emailoctopus.com/api-documentation
EMAILOCTOPUS_API_KEY=
# List ID can be found in the URL as a UUID after clicking a list on https://emailoctopus.com/lists
# or the settings page of your list https://emailoctopus.com/lists/{UUID}/settings
EMAILOCTOPUS_LIST_ID=

# Create Beehiiv API key at https://developers.beehiiv.com/docs/v2/bktd9a7mxo67n-create-an-api-key
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=
